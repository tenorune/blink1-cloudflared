# Copy to .env and edit. The script auto-loads .env if present.
# All values are optional — defaults shown below.

# cloudflared Prometheus metrics endpoint
METRICS_URL=http://localhost:20241/metrics

# Poll interval (seconds) and HTTP flash duration (milliseconds)
POLL_INTERVAL=1
HTTP_FLASH_MS=180

# Local SSH port to watch for cloudflared->sshd connections
SSH_PORT=22

# Colors as R,G,B (0-255). Bump these up if the LED looks unlit.
COLOR_HEALTHY=0,0,40       # dim blue   — tunnel up, idle
COLOR_SSH=90,40,0          # amber      — SSH session active
COLOR_HTTP=0,255,0         # green      — HTTP request flash
COLOR_DOWN=40,0,0          # dim red    — metrics endpoint unreachable

# Override blink1-tool path if it's not on PATH
# BLINK1_TOOL=/opt/homebrew/bin/blink1-tool
